{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "papyrusSSE",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "header"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        }
      ]
    },
    "header": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "(?i)scriptname"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "(?i)extends"
                },
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "SYMBOL",
                "name": "_scriptFlags"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_terminator"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "docString"
                },
                {
                  "type": "SYMBOL",
                  "name": "_terminator"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_terminator": {
      "type": "STRING",
      "value": "\n"
    },
    "docString": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?s)[{].*?}"
      }
    },
    "_term": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "bool"
        },
        {
          "type": "SYMBOL",
          "name": "int"
        },
        {
          "type": "SYMBOL",
          "name": "float"
        },
        {
          "type": "SYMBOL",
          "name": "none"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "parameter": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                },
                {
                  "type": "SYMBOL",
                  "name": "pureAssignment"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        }
      ]
    },
    "_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "import"
            },
            {
              "type": "SYMBOL",
              "name": "variableDefinition"
            },
            {
              "type": "SYMBOL",
              "name": "functionCall"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_terminator"
        }
      ]
    },
    "import": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "(?i)import"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "variableDefinition": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "type"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "pureAssignment"
                },
                {
                  "type": "SYMBOL",
                  "name": "_expression"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "functionCall": {
      "type": "SYMBOL",
      "name": "callExpression"
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_term"
        },
        {
          "type": "SYMBOL",
          "name": "callExpression"
        },
        {
          "type": "SYMBOL",
          "name": "dotExpression"
        }
      ]
    },
    "dotExpression": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "callExpression"
            },
            {
              "type": "SYMBOL",
              "name": "length"
            }
          ]
        }
      ]
    },
    "callExpression": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "parameter"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "REPEAT",
                      "content": {
                        "type": "SEQ",
                        "members": [
                          {
                            "type": "STRING",
                            "value": ","
                          },
                          {
                            "type": "SYMBOL",
                            "name": "parameter"
                          }
                        ]
                      }
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "pureAssignment": {
      "type": "STRING",
      "value": "="
    },
    "type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_primitiveType"
        },
        {
          "type": "SYMBOL",
          "name": "_arrayType"
        }
      ]
    },
    "_arrayType": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_primitiveType"
        },
        {
          "type": "STRING",
          "value": "[]"
        }
      ]
    },
    "_primitiveType": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "(?i)bool"
        },
        {
          "type": "PATTERN",
          "value": "(?i)float"
        },
        {
          "type": "PATTERN",
          "value": "(?i)int"
        },
        {
          "type": "PATTERN",
          "value": "(?i)string"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "bool": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "(?i)true"
        },
        {
          "type": "PATTERN",
          "value": "(?i)false"
        }
      ]
    },
    "int": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "-?[0-9]+"
        },
        {
          "type": "PATTERN",
          "value": "(?i)(0x)[0-9a-f]+"
        }
      ]
    },
    "float": {
      "type": "PATTERN",
      "value": "-?[0-9]+.[0-9]+"
    },
    "string": {
      "type": "PATTERN",
      "value": "\"(.?+)\""
    },
    "none": {
      "type": "PATTERN",
      "value": "(?i)none"
    },
    "length": {
      "type": "PATTERN",
      "value": "(?i)length"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "(?i)[a-z_][a-z0-9_]*"
    },
    "_scriptFlags": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "conditional"
        },
        {
          "type": "SYMBOL",
          "name": "hidden"
        }
      ]
    },
    "_variableFlags": {
      "type": "SYMBOL",
      "name": "conditional"
    },
    "conditional": {
      "type": "PATTERN",
      "value": "(?i)conditional"
    },
    "hidden": {
      "type": "PATTERN",
      "value": "(?i)hidden"
    }
  },
  "extras": [
    {
      "type": "STRING",
      "value": "\\\n"
    },
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}